# Copy this file to `.env.local` and fill in the values.
# Vite exposes only VITE_*-prefixed variables to the client bundle.

# Voxtral TTS — Mistral's hosted text-to-speech API
VITE_MISTRAL_API_KEY=
VITE_MISTRAL_TTS_URL=https://api.mistral.ai/v1/audio/speech
VITE_MISTRAL_TTS_MODEL=voxtral-mini-tts-2603
# Optional. If left empty, the app uses Voxtral's built-in neutral
# English preset "en_paul_neutral" — no voice cloning required.
# Other presets: en_paul_cheerful, gb_jane_neutral, gb_oliver_neutral,
# fr_marie_neutral, etc. (see https://huggingface.co/spaces/mistralai/voxtral-tts-demo)
VITE_MISTRAL_TTS_VOICE_ID=

# ── Supabase ──────────────────────────────────────────────────
# Project URL + anon (publishable) key from
# https://app.supabase.com/project/_/settings/api
# These are safe to expose to the client when Row-Level Security
# is enabled on every table (see supabase/schema.sql).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
